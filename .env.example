# ─── Общие настройки ───
DEBUG=false
LOG_LEVEL=INFO

# ─── База данных ───
DATABASE_URL=sqlite+aiosqlite:///./accessible_learning.db

# ─── Yandex Cloud (ОБЯЗАТЕЛЬНО) ───
# Получите ключ в Yandex Cloud Console: https://console.yandex.cloud/
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here
YANDEX_GPT_MODEL=yandexgpt-lite

# ─── Qdrant (векторная БД, ОБЯЗАТЕЛЬНО) ───
# При запуске через Docker Compose используйте http://qdrant:6333
# При локальном запуске используйте http://localhost:6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=knowledge_base
QDRANT_API_KEY=